<html>
<head><title>{{ title }}</title></head>
<body>
    <h1>{{ heading }}</h1>
    <ul>
        {% for item in items %}
        <li>
            <strong>{{ item.name }}</strong>
            <span>{{ item.email }}</span>
            <p>{{ item.bio }}</p>
        </li>
        {% endfor %}
    </ul>
</body>
</html>
